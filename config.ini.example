[jquants]
# API キーは ~/.jquants-api/jquants-api.toml から自動読み込み。
# 上書きが必要な場合のみ指定:
# api_key = your_api_key_here

# Plan: free / light / standard / premium
plan = free

# Cache directory (default: ~/.cache/jquants-mcp)
# cache_dir = ~/.cache/jquants-mcp

# API base URL
# base_url = https://api.jquants.com/v2

[client]
# Max retry attempts for failed requests
# max_retries = 5

# Base delay (seconds) for exponential backoff
# retry_base_delay = 1.0

# Max pages per paginated request
# max_pages = 10

[server]
# Path to TLS certificate file (PEM) for HTTPS
# ssl_certfile = /etc/ssl/certs/server.crt

# Path to TLS private key file (PEM) for HTTPS
# ssl_keyfile = /etc/ssl/private/server.key

# Bearer token for single-user remote authentication (env: MCP_BEARER_TOKEN)
# bearer_token = your_secret_token_here

# AES-256-GCM encryption key for per-user API key storage in multi-user mode (env: MCP_ENCRYPTION_KEY)
# Generate with: python3 -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# encryption_key = your_base64_encoded_32byte_key_here

[oauth]
# OAuth provider: "github" or "google"
# provider = github

# GitHub OAuth App credentials (env: GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET)
# github_client_id = your_github_client_id
# github_client_secret = your_github_client_secret

# Google OAuth 2.0 credentials (env: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET)
# google_client_id = your_google_client_id
# google_client_secret = your_google_client_secret

# Public base URL used for OAuth callback URLs (env: OAUTH_BASE_URL)
# base_url = https://example.com

# Optional JWT signing key for session tokens (env: OAUTH_JWT_SIGNING_KEY)
# jwt_signing_key = your_jwt_signing_key

# Prompt the OAuth consent screen every login (env: OAUTH_REQUIRE_CONSENT)
# require_consent = true

# ---------------------------------------------------------------------------
# GCS (Google Cloud Storage) bulk-download settings — env vars only
# ---------------------------------------------------------------------------
# GCS_BUCKET=your-bucket-name
# GCS_PREFIX=jquants/
# GCS_SYNC_INTERVAL=3600
